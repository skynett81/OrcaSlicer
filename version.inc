# Included by CMakeLists, edited by the build script
# (the version numbers are generated by the build script from the git current label)

set(SLIC3R_APP_NAME "3DPrintForge Slicer")
set(SLIC3R_APP_KEY "3DPrintForgeSlicer")

if(NOT DEFINED BBL_INTERNAL_TESTING)
set(BBL_INTERNAL_TESTING "0")
endif()
# Product version — kept in lockstep with 3DPrintForge Server (one system, one
# version). Bump both projects together. NOTE: SLIC3R_VERSION below is the
# config/.3mf format-compatibility version and is intentionally NOT tied to this
# — changing it would break profile/project migration.
set(FORGE_VERSION "1.1.23")
string(REGEX MATCH "^([0-9]+)\\.([0-9]+)\\.([0-9]+)"
       FORGE_VERSION_MATCH ${FORGE_VERSION})
set(ORCA_VERSION_MAJOR ${CMAKE_MATCH_1})
set(ORCA_VERSION_MINOR ${CMAKE_MATCH_2})
set(ORCA_VERSION_PATCH ${CMAKE_MATCH_3})

set(SLIC3R_VERSION "02.06.00.51")

if (NOT DEFINED ORCA_UPDATER_SIG_KEY)
    set(ORCA_UPDATER_SIG_KEY "" CACHE STRING "Base64url encoded updater signature key")
endif()
