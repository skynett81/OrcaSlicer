<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop">
    <id>com._3dprintforge.Slicer</id>
    <launchable type="desktop-id">com._3dprintforge.Slicer.desktop</launchable>
    <name>3DPrintForge Slicer</name>
    <summary>Get even more perfect prints!</summary>
    <developer id="com.3dprintforge">
        <name>3DPrintForge</name>
    </developer>
    <url type="homepage">https://github.com/skynett81/3dprintforge-slicer</url>
    <url type="bugtracker">https://github.com/skynett81/3dprintforge-slicer/issues/</url>
    <url type="vcs-browser">https://github.com/skynett81/3dprintforge-slicer</url>
    <metadata_license>0BSD</metadata_license>
    <project_license>AGPL-3.0-only</project_license>
    <content_rating type="oars-1.1" />
    <requires>
        <display_length compare="gt">768</display_length>
    </requires>
    <recommends>
        <control>keyboard</control>
        <control>pointing</control>
    </recommends>
    <screenshots>
        <screenshot type="default">
            <image>https://raw.githubusercontent.com/skynett81/3dprintforge-slicer/main/scripts/flatpak/images/1.png</image>
            <caption>A model ready to be sliced on a buildplate.</caption>
        </screenshot>
        <screenshot>
            <image>https://raw.githubusercontent.com/skynett81/3dprintforge-slicer/main/scripts/flatpak/images/2.png</image>
            <caption>A calibration test ready to be printed out.</caption>
        </screenshot>
    </screenshots>
    <description>
        <p>3DPrintForge Slicer is a powerful, free and open-source 3D printer slicer with cutting-edge
            features for FDM printing. It supports a wide range of printers from manufacturers
            including Bambu Lab, Prusa, Voron, Creality, Snapmaker, and many more.</p>
        <p>Key features include advanced calibration tools, adaptive layer heights, tree supports,
            multi-material support, the integrated Forge Library of parametric model generators,
            AMS-aware spool tracking, and an intuitive interface for both beginners and experts.
            3DPrintForge Slicer also provides built-in network printing capabilities for compatible printers.</p>
    </description>
    <branding>
        <color type="primary" scheme_preference="light">#009789</color>
        <color type="primary" scheme_preference="dark">#00665B</color>
    </branding>
    <releases>
        <release version="2.4.0-dev" date="2026-06-06" type="development">
            <url type="details">https://github.com/skynett81/3dprintforge-slicer/releases</url>
            <description>
                <p>See the release page for detailed changelog.</p>
            </description>
        </release>
    </releases>
</component>
